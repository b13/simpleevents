{
	"name": "b13/simpleevents",
	"type": "typo3-cms-extension",
	"description": "Events - Add events in a simple way",
	"license": "GPL-2.0-or-later",
	"keywords": ["TYPO3 CMS", "Events"],
	"require": {
		"typo3/cms-core": "^13.4 || ^14.3"
	},
	"replace": {
		"cmsexperts/simpleevents": "*"
	},
